# op.env — SAFE TO COMMIT: 1Password references only, NO secret values.
# The .env it renders holds REAL secrets and must NEVER be committed (gitignored).
# Render:   make secrets          (op inject → .env)
# Inspect:  make secrets-doctor   (ok/MISSING per reference, values never printed)
# One-off:  op run --env-file=op.env -- <command>
#
# Same pattern & vault as ~/tech/reve (vault: coding-agent). The op CLI needs a
# signed-in session or OP_SERVICE_ACCOUNT_TOKEN.

# ── Anthropic — DEDICATED WORKSPACE key for talent-promo-cma (spec Appendix C #6).
# Create the workspace + scoped key in the Anthropic Console, store it in 1Password
# at this path (new item `anthropic-cma`), then `make secrets`.
ANTHROPIC_API_KEY="op://coding-agent/anthropic-cma/credential"

# ── OpenAI — grounding judge (gpt-5-mini). Absent/unresolvable ⇒ judge runs in
# deterministic stub mode (mock engine still fully works).
OPENAI_API_KEY="op://coding-agent/openai/credential"

# ── Non-secret local defaults (uncomment to override) ────────────────────────
# TP_DEFAULT_ENGINE=mock
# TP_DB_PATH=./data/gateway.db
# TP_MOCK_DELAY_MS=800
# CMA_AGENT_ID=            # written by infra/cma/setup.sh
# CMA_AGENT_VERSION=
# CMA_ENVIRONMENT_ID=
# CMA_MEMORY_STORE_ID=
# CMA_WORKSPACE_ID=
